// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
  READONLY
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  archivedAt    DateTime?
  
  contactsCreated Contact[] @relation("ContactCreator")
  contactsUpdated Contact[] @relation("ContactUpdater")
  tasksAssigned   Task[]
  mailCases       MailCase[]
  writtenQuestions WrittenQuestion[]
  questionsCreated WrittenQuestion[] @relation("QuestionCreator")
  importLogs      ImportLog[]
  auditLogs       AuditLog[]
  documentsUploaded Document[] @relation("UserDocuments")
  statuses        EmployeeStatus[] @relation("UserStatuses")
  notifications   Notification[]
  employeeSetting EmployeeSetting?
  
  // Settings Phase 11.6 relations
  supportLevelChanges ContactSupportLevelHistory[] @relation("UserSupportLevelChanges")
  messageTemplates    MessageTemplate[] @relation("TemplateAuthor")
  apiKeys             ApiKey[] @relation("ApiKeyCreator")
  exportBackupLogs    ExportBackupLog[] @relation("ExportBackupUser")

  // Permanence relations
  ownedPermanences      MobilePermanence[] @relation("PermanenceOwner")
  validatedPermanences  MobilePermanence[] @relation("PermanenceValidator")
  permanenceTasks       PermanenceTask[]
  permanenceSyntheses   PermanenceSynthesis[]
}

model Contact {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  phone             String? // Fixe
  mobilePhone       String? // Portable
  email             String?
  birthDate         DateTime?
  gender            String? // H, F, Autre
  
  streetNumber      String?
  streetName        String?
  postalCode        String?
  city              String?
  address           String? // legacy or full address
  
  territorySector   String?
  supportLevel      String? // e.g. "1", "2", "3", "4", "5"
  meetingStep       String? // Absent, Accepté, Refusé, Repassés, Pas encore contactés
  
  type              String    // ELECTEUR, ELU, ASSO, PARTENAIRE, PRESSE, AUTRE
  source            String?   // PERMANENCE, COURRIER, EVENEMENT, TERRAIN, AUTRE
  newsletter        Boolean   @default(false) // Consentement Email
  smsConsent        Boolean   @default(false) // Consentement SMS (RGPD)
  whatsappStatus    String?   // NON, ENVOYE, REJOINT
  linkedinUrl       String?
  notes             String?
  lastInteraction   DateTime?
  
  createdById       String
  createdBy         User      @relation("ContactCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?     @relation("ContactUpdater", fields: [updatedById], references: [id])
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  archivedAt        DateTime?

  tags              ContactTag[]
  links             GlobalLink[]  @relation("ContactLinks")
  documents         Document[]    @relation("ContactDocuments")
  duplicatesLeft    DuplicateCandidate[] @relation("Contact1")
  duplicatesRight   DuplicateCandidate[] @relation("Contact2")
  supportLevelHistory ContactSupportLevelHistory[] @relation("SupportLevelHistory")
  permanenceContacts    PermanenceContact[]

  @@index([lastName])
  @@index([email])
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  color       String?
  contacts    ContactTag[]
  tasks       TaskTag[]
}

model ContactTag {
  contactId   String
  tagId       String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([contactId, tagId])
}

model TaskTag {
  taskId      String
  tagId       String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([taskId, tagId])
}

model Task {
  id              String    @id @default(cuid())
  title           String
  description     String?
  priority        String    @default("NORMALE") // HAUTE, NORMALE, BASSE
  status          String    @default("A_FAIRE") // A_FAIRE, EN_COURS, EN_ATTENTE, TERMINEE, ANNULEE
  dueDate         DateTime?
  expectedDeliverable String?
  
  assigneeId      String?
  assignee        User?     @relation(fields: [assigneeId], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?
  cancelledAt     DateTime?
  
  subtasks        Subtask[]
  comments        TaskComment[]
  links           GlobalLink[] @relation("TaskLinks")
  documents       Document[]   @relation("TaskDocuments")
  tags            TaskTag[]

  @@index([status])
  @@index([assigneeId])
}

model Subtask {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean   @default(false)
}

model TaskComment {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime  @default(now())
}

model MailCase {
  id              String    @id @default(cuid())
  reference       String    @unique // COU-2026-0042
  type            String    @default("ENTRANT") // ENTRANT, SORTANT
  receiveDate     DateTime?
  sentDate        DateTime?
  channel         String    // POSTAL, MAIL, AUTRE
  senderName      String?
  recipientName   String?
  city            String?
  subject         String
  category        String?
  urgency         String    @default("NORMALE")
  status          String    @default("RECU") // RECU, LU, EN_TRAITEMENT, REPONDU, CLASSE, ENVOYE
  content         String?
  notes           String?
  
  responseDueDate  DateTime?
  responseSentDate DateTime?
  
  parentMailCaseId String?
  parentMailCase   MailCase?  @relation("MailReplies", fields: [parentMailCaseId], references: [id])
  replies          MailCase[] @relation("MailReplies")
  
  assigneeId      String?
  assignee        User?     @relation(fields: [assigneeId], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  links           GlobalLink[] @relation("MailLinks")
  documents       Document[]   @relation("MailDocuments")

  @@index([reference])
  @@index([status])
  @@index([assigneeId])
}

model WrittenQuestion {
  id              String    @id @default(cuid())
  anNumber        String?   // numéro AN
  title           String
  type            String    // QE, QAG, AMENDEMENT
  ministry        String?
  theme           String?
  depositDate     DateTime?
  responseDate    DateTime?
  status          String    @default("DEPOSEE") // DEPOSEE, EN_ATTENTE, REPONSE_RECUE, RETOUR_EFFECTUE
  concernedPerson String?
  feedbackNeeded  Boolean   @default(false)
  followUpDescription String?
  followUpDueDate DateTime?
  content         String?
  responseContent String?
  notes           String?
  
  responseDeadlineDate DateTime?
  responseReceivedDate DateTime?
  reminderStatus       String?
  redepositSuggested   Boolean   @default(false)
  redepositDate        DateTime?
  linkedOriginalQeId   String?
  followUpAction       String?
  followUpNotes        String?
  
  assigneeId      String?
  assignee        User?     @relation(fields: [assigneeId], references: [id])
  
  createdById     String?
  createdBy       User?     @relation("QuestionCreator", fields: [createdById], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archivedAt      DateTime?
  
  links           GlobalLink[] @relation("QuestionLinks")
  documents       Document[]   @relation("QuestionDocuments")

  @@index([anNumber])
  @@index([status])
  @@index([assigneeId])
}

model EmployeeStatus {
  id          String    @id @default(cuid())
  employeeId  String
  employee    User      @relation("UserStatuses", fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime  // Stockée à 00:00:00
  status      String    // PARIS, CIRCO, TELETRAVAIL, DEPLACEMENT, CONGE, MALADIE, ABSENT
  dayType     String    @default("worked") // worked, off, paid_leave
  notes       String?
  updatedById String?
  
  @@unique([employeeId, date])
  @@index([date])
}

model EmployeeSetting {
  id                          String    @id @default(cuid())
  userId                      String    @unique
  user                        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  annualWorkingDays           Int       @default(218)
  referencePeriodStartMonth   Int       @default(6) // Juin par défaut
  referencePeriodStartDay     Int       @default(1)
  
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}

// GlobalLink permet de lier des entités entre elles (ex: un Contact avec une Tâche)
model GlobalLink {
  id              String    @id @default(cuid())
  contactId       String?
  contact         Contact?  @relation("ContactLinks", fields: [contactId], references: [id])
  taskId          String?
  task            Task?     @relation("TaskLinks", fields: [taskId], references: [id])
  mailCaseId      String?
  mailCase        MailCase? @relation("MailLinks", fields: [mailCaseId], references: [id])
  questionId      String?
  question        WrittenQuestion? @relation("QuestionLinks", fields: [questionId], references: [id])
  
  createdAt       DateTime  @default(now())
}

model ImportLog {
  id          String    @id @default(cuid())
  filename    String
  importDate  DateTime  @default(now())
  status      String    // SUCCESS, FAILED, PARTIAL
  rowsImported Int      @default(0)
  
  userId      String
  user        User      @relation(fields: [userId], references: [id])
}

model DuplicateCandidate {
  id          String    @id @default(cuid())
  contact1Id  String
  contact1    Contact   @relation("Contact1", fields: [contact1Id], references: [id])
  contact2Id  String
  contact2    Contact   @relation("Contact2", fields: [contact2Id], references: [id])
  reason      String    // "NOM_EMAIL", "NOM_PHONE"
  status      String    @default("PENDING") // PENDING, RESOLVED
  
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id          String    @id @default(cuid())
  action      String    // ex: "user.create", "module.disable"
  entity      String    @map("entityType") // ex: "User", "Module", "Contact"
  entityId    String?
  
  oldValues   String?   // JSON legacy
  newValues   String?   // JSON legacy
  details     Json?
  ip          String?
  
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime  @default(now())

  @@index([entityId])
  @@index([entity])
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique  // ex: "contacts.read", "users.delete"
  label           String
  module          String           // ex: "contacts", "admin"
  rolePermissions RolePermission[]
}

model RolePermission {
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([role, permissionId])
}

model Module {
  id        String   @id @default(cuid())
  key       String   @unique  // "contacts" | "tasks" | "mailcases" | "questions" | "agenda" | "reports"
  label     String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  pages     Page[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id           String   @id @default(cuid())
  slug         String   @unique  // ex: "/contacts", "/contacts/new"
  label        String
  icon         String?
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id])
  permission   String?  // clé de permission requise pour accéder, nullable = public authed
  order        Int      @default(0)
  isVisible    Boolean  @default(true)  // visible dans la sidebar
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  archivedAt   DateTime?
}

model Setting {
  key       String      @id   // ex: "app.name", "auth.session_ttl"
  value     String
  type      SettingType @default(STRING)
  category  String      // ex: "general", "auth", "email", "rgpd"
  label     String
  updatedAt DateTime    @updatedAt
}

model Document {
  id              String    @id @default(cuid())
  title           String
  description     String?
  documentType    String    @default("AUTRE") // PDF, WORD, COURRIER, QE, NOTE, AUTRE
  originalName    String
  storageName     String
  extension       String
  mimeType        String
  size            Int
  storagePath     String
  fileHash        String?
  
  contactId       String?
  contact         Contact?  @relation("ContactDocuments", fields: [contactId], references: [id], onDelete: Cascade)
  taskId          String?
  task            Task?     @relation("TaskDocuments", fields: [taskId], references: [id], onDelete: Cascade)
  mailCaseId      String?
  mailCase        MailCase? @relation("MailDocuments", fields: [mailCaseId], references: [id], onDelete: Cascade)
  questionId      String?
  question        WrittenQuestion? @relation("QuestionDocuments", fields: [questionId], references: [id], onDelete: Cascade)
  
  tags            String?   // JSON array
  status          String    @default("VALIDATED") // DRAFT, PENDING, VALIDATED, REJECTED
  confidentiality String    @default("INTERNE") // INTERNE, RESTREINT, SENSIBLE, CONFIDENTIEL
  
  uploadedById    String
  uploadedBy      User      @relation("UserDocuments", fields: [uploadedById], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archivedAt      DateTime?
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // OVERDUE, DUE_TOMORROW, ASSIGNED, STATUS_CHANGE, COMMENT_ADDED
  title       String
  message     String
  relatedType String?   // ex: "Task"
  relatedId   String?   // ex: id de la tâche
  severity    String    @default("INFO") // INFO, WARNING, URGENT
  readAt      DateTime?
  
  createdAt   DateTime  @default(now())
}

// ==========================================
// MODELS FOR SETTINGS (PHASE 11.6)
// ==========================================

model AppSetting {
  id           String    @id @default(cuid())
  key          String    @unique
  value        String?
  type         String    @default("STRING") // STRING, BOOLEAN, NUMBER, JSON
  category     String    // GENERAL, SECURITY, RGPD
  label        String?
  description  String?
  isSensitive  Boolean   @default(false)
  updatedById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ModuleSetting {
  id           String    @id @default(cuid())
  moduleName   String    @unique // CONTACTS, TASKS, MAILS
  displayName  String
  icon         String?
  order        Int       @default(0)
  isActive     Boolean   @default(true)
  visibleRoles String    // JSON array: '["ADMIN", "SUPERADMIN"]'
  updatedAt    DateTime  @updatedAt
}

model SystemList {
  id          String    @id @default(cuid())
  category    String    // CONTACT_TYPE, CONTACT_SOURCE, SUPPORT_LEVEL, MAIL_CATEGORY
  value       String
  color       String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  isSensitive Boolean   @default(false)
  createdAt   DateTime  @default(now())
  
  @@unique([category, value])
  @@index([category])
}

model ContactSupportLevelHistory {
  id              String    @id @default(cuid())
  contactId       String
  contact         Contact   @relation("SupportLevelHistory", fields: [contactId], references: [id], onDelete: Cascade)
  previousLevel   String?
  newLevel        String?
  changedById     String
  user            User      @relation("UserSupportLevelChanges", fields: [changedById], references: [id])
  reason          String?
  createdAt       DateTime  @default(now())
  
  @@index([contactId])
}

model MessageTemplate {
  id          String    @id @default(cuid())
  name        String
  channel     String    // EMAIL, SMS, WHATSAPP
  subject     String?
  content     String
  variables   String    // JSON array of allowed variables
  isActive    Boolean   @default(true)
  authorId    String
  author      User      @relation("TemplateAuthor", fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Integration {
  id          String    @id @default(cuid())
  provider    String    @unique // BREVO, WHATSAPP, GCAL
  isActive    Boolean   @default(false)
  settings    String?   // JSON
  secrets     String?   // JSON
  lastTestAt  DateTime?
  logs        String?
  updatedAt   DateTime  @updatedAt
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  prefix      String
  scopes      String    // JSON array
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdById String
  creator     User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
}

model AutomationRule {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(false)
  frequency   String    // Cron expression
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastStatus  String?
}

model ExportBackupLog {
  id          String    @id @default(cuid())
  type        String    // EXPORT_CONTACTS, BACKUP_DB
  status      String    // SUCCESS, FAILED
  details     String?
  userId      String?
  user        User?     @relation("ExportBackupUser", fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

enum OrgType {
  COMMERCE
  ASSOCIATION
  MAIRIE
  MEDIA
  INSTITUTION
  OTHER
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  type        OrgType   @default(OTHER)
  sector      String?
  address     String?
  city        String?
  zipCode     String?
  phone       String?
  email       String?
  website     String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  permanenceOrganizations PermanenceOrganization[]
}

model Commune {
  id          String    @id @default(cuid())
  name        String
  zipCode     String
  inseeCode   String?   @unique
  department  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  permanenceLocations PermanenceLocation[]
}

enum PermanenceStatus {
  DRAFT         // Brouillon
  IN_PROGRESS   // En préparation
  TO_CORRECT    // À corriger
  READY         // Prête
  VALIDATED     // Validée
  ARCHIVED      // Archivée
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  IMPOSSIBLE
}

enum CallStatus {
  NOT_CALLED
  REACHED
  ABSENT
  VOICEMAIL
  APPOINTMENT_CONFIRMED
  CALLBACK_REQUESTED
  REFUSED
}

enum ContactRole {
  PHONING
  ELU
  INSTITUTIONNEL
  PRESSE
  COMMERCANT
  CITOYEN
}

model MobilePermanence {
  id                 String             @id @default(cuid())
  title              String
  status             PermanenceStatus   @default(DRAFT)
  score              Int                @default(0)  // 0-100, calculé côté serveur
  scheduledStartDate DateTime
  ownerUserId        String
  ownerUser          User               @relation("PermanenceOwner", fields: [ownerUserId], references: [id])
  validationUserId   String?
  validationUser     User?              @relation("PermanenceValidator", fields: [validationUserId], references: [id])
  validationComment  String?
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  archivedAt         DateTime?

  locations         PermanenceLocation[]
  tasks             PermanenceTask[]
  contacts          PermanenceContact[]
  organizations     PermanenceOrganization[]
  synthesis         PermanenceSynthesis?
}

model PermanenceLocation {
  id              String    @id @default(cuid())
  permanenceId    String
  permanence      MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  communeId       String?
  commune         Commune?  @relation(fields: [communeId], references: [id])
  communeName     String    // Dénormalisé pour affichage si commune libre
  date            DateTime
  startTime       String?   // "09:00"
  endTime         String?   // "12:00"
  address         String?
  parkingNotes    String?
  parkingStatus   TaskStatus @default(TODO)
  mairieContactId String?
  order           Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PermanenceTask {
  id             String    @id @default(cuid())
  permanenceId   String
  permanence     MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  section        String    // "communication" | "phoning" | "courrier" | "commercants" | "institutionnel" | "logistique"
  label          String
  status         TaskStatus @default(TODO)
  assigneeUserId String?
  assigneeUser   User?     @relation(fields: [assigneeUserId], references: [id])
  dueDate        DateTime?
  required       Boolean   @default(false)
  comment        String?
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PermanenceContact {
  id                       String      @id @default(cuid())
  permanenceId             String
  permanence               MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  contactId                String?
  contact                  Contact?    @relation(fields: [contactId], references: [id])
  // Champs dénormalisés pour import CSV (contact sans fiche CRM)
  firstName                String?
  lastName                 String?
  phone                    String?
  email                    String?
  city                     String?
  role                     ContactRole @default(PHONING)
  callStatus               CallStatus  @default(NOT_CALLED)
  requestSummary           String?
  requiresDeputyAttention  Boolean     @default(false)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
}

model PermanenceOrganization {
  id                  String       @id @default(cuid())
  permanenceId        String
  permanence          MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  // Champs dénormalisés si organisation non CRM
  orgName             String?
  type                OrgType      @default(COMMERCE)
  sector              String?
  attitude            String?      // "favorable" | "neutre" | "defavorable"
  concern             String?
  visitRecommended    Boolean      @default(false)
  visited             Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model PermanenceSynthesis {
  id               String    @id @default(cuid())
  permanenceId     String    @unique
  permanence       MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  attentionPoints  String?
  merchantProgram  String?
  phoningTopics    String?
  recommendations  String?
  signedByUserId   String?
  signedByUser     User?     @relation(fields: [signedByUserId], references: [id])
  signedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
