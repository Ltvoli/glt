// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMINISTRATEUR
  SUPERVISEUR
  COORDINATEUR
  USER
  SUPERADMIN
  ADMIN
  READONLY
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  firstName    String
  lastName     String
  mobilePhone  String?
  passwordHash String
  role         Role    @default(USER)
  isActive     Boolean @default(true)
  avatarUrl    String?
  locale       String  @default("fr")
  timezone     String  @default("Europe/Paris")
  theme        String  @default("system")

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String? // Chiffré AES-256-GCM via src/lib/crypto.ts

  invitedAt       DateTime?
  invitedByUserId String?
  invitedBy       User?     @relation("UserInvitations", fields: [invitedByUserId], references: [id])
  invitedUsers    User[]    @relation("UserInvitations")

  lastLoginAt DateTime?
  lastLoginIp String?
  suspendedAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  sessions           UserSession[]
  auditLogs          AuditLog[]
  apiKeys            ApiKey[]
  invitationsCreated Invitation[]  @relation("UserInvitationsCreated")

  // Business relations to preserve
  contactsCreated   Contact[]         @relation("ContactCreator")
  contactsUpdated   Contact[]         @relation("ContactUpdater")
  tasksAssigned     Task[]
  mailCases         MailCase[]
  versionsCreated   MailVersion[]     @relation("VersionEditor")
  mailComments      MailComment[]     @relation("CommentAuthor")
  writtenQuestions  WrittenQuestion[]
  questionsCreated  WrittenQuestion[] @relation("QuestionCreator")
  importLogs        ImportLog[]
  documentsUploaded Document[]        @relation("UserDocuments")
  statuses          EmployeeStatus[]  @relation("UserStatuses")
  notifications     Notification[]
  employeeSetting   EmployeeSetting?

  supportLevelChanges ContactSupportLevelHistory[] @relation("UserSupportLevelChanges")
  messageTemplates    MessageTemplate[]            @relation("TemplateAuthor")
  exportBackupLogs    ExportBackupLog[]            @relation("ExportBackupUser")

  // Permanence relations
  ownedPermanences     MobilePermanence[]    @relation("PermanenceOwner")
  validatedPermanences MobilePermanence[]    @relation("PermanenceValidator")
  permanenceTasks      PermanenceTask[]
  permanenceTaskHistories PermanenceTaskHistory[]
  permanenceSyntheses  PermanenceSynthesis[]
  bulkCommunications   BulkCommunication[]   @relation("BulkCommsCreator")
  interactionsCreated  ContactInteraction[]
  taskComments         TaskComment[]         @relation("TaskCommentAuthor")
  savedFilters         SavedFilter[]
}

model UserSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti          String    @unique
  deviceType   String    @default("WEB")
  deviceName   String?
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  @@index([userId])
  @@index([jti])
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  role        Role      @default(USER)
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  invitedBy   User      @relation("UserInvitationsCreated", fields: [invitedById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([email])
  @@index([token])
}

model Contact {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  usageName   String? // Nom d'usage
  phone       String? // Fixe
  mobilePhone String? // Portable
  email       String?
  birthDate   DateTime?
  gender      String? // H, F, Autre
  nationality String? // Nationalité
  profession  String?

  apartment         String? // Appartement
  building          String? // Bâtiment
  streetNumber      String?
  streetName        String?
  addressComplement String? // Complément d'adresse
  postalCode        String?
  city              String?
  address      String? // legacy or full address
  buildingType String? // Type de bâtiment
  floor        String? // Étage
  door         String? // Porte

  supportLevel    String? // e.g. "1", "2", "3", "4", "5"

  ageRange          String?
  lastContactMobile DateTime?
  territory         String?
  department        String?

  type            String // ELECTEUR, ELU, ASSO, PARTENAIRE, PRESSE, AUTRE, CONTACT_MAIRIE
  consentEmail    Boolean? // Consentement Email (RGPD)
  consentPhone    Boolean? // Consentement Téléphone (RGPD)
  consentSms      Boolean? // Consentement SMS (RGPD)
  consentPostal   Boolean? // Consentement Postal (RGPD)
  consentCustom   Boolean? // Consentement Personnalisé (RGPD)
  noContact       Boolean   @default(false) // Ne plus jamais contacter
  isNpai          Boolean   @default(false)
  consentDate     DateTime? // Date d'obtention du consentement
  consentSource   String?   // Origine du consentement
  whatsappStatus  String? // NON, ENVOYE, REJOINT
  linkedinUrl     String?
  notes           String?
  lastInteraction DateTime?

  createdById String
  createdBy   User    @relation("ContactCreator", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("ContactUpdater", fields: [updatedById], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  tags                ContactTag[]
  links               GlobalLink[]                 @relation("ContactLinks")
  documents           Document[]                   @relation("ContactDocuments")
  duplicatesLeft      DuplicateCandidate[]         @relation("Contact1")
  duplicatesRight     DuplicateCandidate[]         @relation("Contact2")
  supportLevelHistory ContactSupportLevelHistory[] @relation("SupportLevelHistory")
  permanenceContacts  PermanenceContact[]
  permanenceMailContacts PermanenceMailContact[]   @relation("MailContactRelation")
  permanenceLocations PermanenceLocation[]         @relation("LocationMairieContact")
  lists               ContactList[]
  interactions        ContactInteraction[]

  @@index([lastName])
  @@index([email])
  @@index([firstName(ops: raw("gin_trgm_ops"))], type: Gin, map: "Contact_firstName_trgm_idx")
  @@index([lastName(ops: raw("gin_trgm_ops"))], type: Gin, map: "Contact_lastName_trgm_idx")
  @@index([email(ops: raw("gin_trgm_ops"))], type: Gin, map: "Contact_email_trgm_idx")
  @@index([city(ops: raw("gin_trgm_ops"))], type: Gin, map: "Contact_city_trgm_idx")
}

model ContactInteraction {
  id          String   @id @default(cuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type        String   // APPEL_ENTRANT, APPEL_SORTANT, RENCONTRE_PHYSIQUE, SMS
  date        DateTime @default(now())
  notes       String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
}

model Tag {
  id         String   @id @default(cuid())
  name       String   @unique
  color      String   @default("#6366f1")
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations to preserve
  contacts ContactTag[]
  tasks    TaskTag[]
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model TaskTag {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model Task {
  id                  String    @id @default(cuid())
  title               String
  description         String?
  priority            String    @default("NORMALE") // HAUTE, NORMALE, BASSE
  status              String    @default("A_FAIRE") // A_FAIRE, EN_COURS, EN_ATTENTE, TERMINEE, ANNULEE
  dueDate             DateTime?
  expectedDeliverable String?

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?

  subtasks  Subtask[]
  comments  TaskComment[]
  links     GlobalLink[]  @relation("TaskLinks")
  documents Document[]    @relation("TaskDocuments")
  tags      TaskTag[]

  isRecurring        Boolean   @default(false)
  recurrencePattern  String?   // "DAILY", "WEEKLY", "MONTHLY"
  recurrenceInterval Int?      @default(1)
  nextOccurrence     DateTime?
  isTemplate         Boolean   @default(false)
  parentTaskId       String?
  parentTask         Task?     @relation("TaskOccurrences", fields: [parentTaskId], references: [id], onDelete: SetNull)
  occurrences        Task[]    @relation("TaskOccurrences")

  @@index([status])
  @@index([assigneeId])
  @@index([title])
}

model Subtask {
  id          String  @id @default(cuid())
  taskId      String
  task        Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean @default(false)
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  authorId  String?
  author    User?    @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

model MailCase {
  id            String    @id @default(cuid())
  reference     String    @unique // COU-2026-0042
  type          String    @default("ENTRANT") // ENTRANT, SORTANT
  receiveDate   DateTime?
  sentDate      DateTime?
  channel       String // POSTAL, MAIL, AUTRE
  senderName    String?
  recipientName String?
  city          String?
  subject       String
  category      String?
  urgency       String    @default("NORMALE")
  status        String    @default("RECU") // RECU, LU, EN_TRAITEMENT, REPONDU, CLASSE, ENVOYE
  validationStatus String? // A_VALIDER, VALIDE, REJETE (null si non applicable)
  rejectionReason  String?
  content       String?
  notes         String?

  aiAnalysis       Json?
  aiSuggestions    Json?
  hideAiAssistant  Boolean   @default(false)

  versions      MailVersion[] @relation("MailVersions")
  comments      MailComment[] @relation("MailComments")

  responseDueDate  DateTime?
  responseSentDate DateTime?

  parentMailCaseId String?
  parentMailCase   MailCase?  @relation("MailReplies", fields: [parentMailCaseId], references: [id], onDelete: SetNull)
  replies          MailCase[] @relation("MailReplies")

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links     GlobalLink[] @relation("MailLinks")
  documents Document[]   @relation("MailDocuments")

  @@index([reference])
  @@index([status])
  @@index([assigneeId])
  @@index([subject])
  @@index([senderName])
  @@index([recipientName])
}

model MailVersion {
  id         String   @id @default(cuid())
  mailCaseId String
  mailCase   MailCase @relation("MailVersions", fields: [mailCaseId], references: [id], onDelete: Cascade)
  content    String?
  subject    String
  editedById String
  editedBy   User     @relation("VersionEditor", fields: [editedById], references: [id])
  createdAt  DateTime @default(now())
  @@index([mailCaseId])
}

model MailComment {
  id         String   @id @default(cuid())
  mailCaseId String
  mailCase   MailCase @relation("MailComments", fields: [mailCaseId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("CommentAuthor", fields: [authorId], references: [id])
  content    String
  createdAt  DateTime @default(now())
  @@index([mailCaseId])
}

model WrittenQuestion {
  id                  String    @id @default(cuid())
  anNumber            String? // numéro AN
  title               String
  type                String // QE, QAG, AMENDEMENT
  ministry            String?
  theme               String?
  depositDate         DateTime?
  responseDate        DateTime?
  status              String    @default("A_REDIGER") // A_REDIGER, VALIDER, REFUSE, TERMINE
  concernedPerson     String?
  feedbackNeeded      Boolean   @default(false)
  followUpDescription String?
  followUpDueDate     DateTime?
  content             String?
  responseContent     String?
  notes               String?

  responseDeadlineDate DateTime?
  responseReceivedDate DateTime?
  reminderStatus       String?
  redepositSuggested   Boolean   @default(false)
  redepositDate        DateTime?
  linkedOriginalQeId   String?
  followUpAction       String?
  followUpNotes        String?

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id])

  createdById String?
  createdBy   User?   @relation("QuestionCreator", fields: [createdById], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  links     GlobalLink[] @relation("QuestionLinks")
  documents Document[]   @relation("QuestionDocuments")

  @@index([anNumber])
  @@index([status])
  @@index([assigneeId])
  @@index([title])
  @@index([ministry])
}

model EmployeeStatus {
  id          String   @id @default(cuid())
  employeeId  String
  employee    User     @relation("UserStatuses", fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime // Stockée à 00:00:00
  status      String // PARIS, CIRCO, TELETRAVAIL, DEPLACEMENT, CONGE, MALADIE, ABSENT
  dayType     String   @default("worked") // worked, off, paid_leave
  notes       String?
  updatedById String?

  @@unique([employeeId, date])
  @@index([date])
}

model EmployeeSetting {
  id                        String @id @default(cuid())
  userId                    String @unique
  user                      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  annualWorkingDays         Int    @default(218)
  referencePeriodStartMonth Int    @default(6) // Juin par défaut
  referencePeriodStartDay   Int    @default(1)
  showInPlanning            Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// GlobalLink permet de lier des entités entre elles (ex: un Contact avec une Tâche)
model GlobalLink {
  id         String           @id @default(cuid())
  contactId  String?
  contact    Contact?         @relation("ContactLinks", fields: [contactId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?            @relation("TaskLinks", fields: [taskId], references: [id], onDelete: Cascade)
  mailCaseId String?
  mailCase   MailCase?        @relation("MailLinks", fields: [mailCaseId], references: [id], onDelete: Cascade)
  questionId String?
  question   WrittenQuestion? @relation("QuestionLinks", fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ImportLog {
  id           String   @id @default(cuid())
  filename     String
  importDate   DateTime @default(now())
  status       String // SUCCESS, FAILED, PARTIAL
  rowsImported Int      @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model DuplicateCandidate {
  id         String  @id @default(cuid())
  contact1Id String
  contact1   Contact @relation("Contact1", fields: [contact1Id], references: [id], onDelete: Cascade)
  contact2Id String
  contact2   Contact @relation("Contact2", fields: [contact2Id], references: [id], onDelete: Cascade)
  reason     String // "NOM_EMAIL", "NOM_PHONE"
  status     String  @default("PENDING") // PENDING, RESOLVED

  createdAt DateTime @default(now())
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  label           String
  description     String?
  module          String
  rolePermissions RolePermission[]
}

model RolePermission {
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([role, permissionId])
}

model Module {
  id            String   @id @default(cuid())
  key           String   @unique
  label         String
  icon          String?
  description   String?
  color         String?
  bg            String?
  isActive      Boolean  @default(true)
  showInSidebar Boolean  @default(true)
  order         Int      @default(0)
  pages         Page[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Page {
  id         String    @id @default(cuid())
  slug       String    @unique
  label      String
  icon       String?
  moduleId   String
  module     Module    @relation(fields: [moduleId], references: [id])
  permission String?
  order      Int       @default(0)
  isVisible  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
}

model FieldConfig {
  id           String  @id @default(cuid())
  module       String  // ex: "contacts", "tasks", "mailcases"
  section      String? // ex: "État civil", "Adresse"
  fieldKey     String  // ex: "firstName", "lastName"
  defaultLabel String  // Libellé d'origine
  customLabel  String? // Libellé personnalisé par l'admin
  isVisible    Boolean @default(true)
  order        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([module, fieldKey])
}

model Setting {
  key       String      @id
  value     String
  type      SettingType @default(STRING)
  category  String
  label     String
  updatedAt DateTime    @updatedAt
}

model SupportLevel {
  id        String   @id @default(cuid())
  label     String
  color     String   @default("#6366f1")
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
}

model Webhook {
  id           String    @id @default(cuid())
  name         String
  url          String
  events       String[]
  isActive     Boolean   @default(true)
  secret       String
  lastCalledAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AppDictionary {
  id        String   @id @default(cuid())
  type      String // ex: "MAIL_STATUS", "CONTACT_TYPE", "TASK_STATUS"
  code      String // La valeur technique stockée en DB (ex: "EN_COURS")
  label     String // L'affichage humain (ex: "En cours")
  color     String? // Couleur du tag
  icon      String? // Icône optionnelle
  order     Int      @default(0) // Tri
  isActive  Boolean  @default(true) // Permet de masquer sans supprimer
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, code])
  @@index([type])
}

model WorkspaceSettings {
  id                    String   @id @default("singleton")
  name                  String   @default("Bureau Parlementaire")
  logoUrl               String?
  force2FA              Boolean  @default(false)
  ipAllowlist           String?
  sessionTimeoutMinutes Int      @default(1440)
  mobileAccessEnabled   Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())
}

model Document {
  id           String  @id @default(cuid())
  title        String
  description  String?
  documentType String  @default("AUTRE") // PDF, WORD, COURRIER, QE, NOTE, AUTRE
  originalName String
  storageName  String
  extension    String
  mimeType     String
  size         Int
  storagePath  String
  fileHash     String?
  extractedText String?

  contactId  String?
  contact    Contact?         @relation("ContactDocuments", fields: [contactId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?            @relation("TaskDocuments", fields: [taskId], references: [id], onDelete: Cascade)
  mailCaseId String?
  mailCase   MailCase?        @relation("MailDocuments", fields: [mailCaseId], references: [id], onDelete: Cascade)
  questionId String?
  question   WrittenQuestion? @relation("QuestionDocuments", fields: [questionId], references: [id], onDelete: Cascade)

  tags            String? // JSON array
  status          String  @default("VALIDATED") // DRAFT, PENDING, VALIDATED, REJECTED
  confidentiality String  @default("INTERNE") // INTERNE, RESTREINT, SENSIBLE, CONFIDENTIEL

  uploadedById String
  uploadedBy   User   @relation("UserDocuments", fields: [uploadedById], references: [id])

  folderId     String?
  folder       DocumentFolder?  @relation("FolderDocuments", fields: [folderId], references: [id], onDelete: SetNull)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
}

model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  color     String           @default("#64748b")
  parentId  String?
  parent    DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  DocumentFolder[] @relation("FolderHierarchy")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  documents Document[]       @relation("FolderDocuments")
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // OVERDUE, DUE_TOMORROW, ASSIGNED, STATUS_CHANGE, COMMENT_ADDED
  title       String
  message     String
  relatedType String? // ex: "Task"
  relatedId   String? // ex: id de la tâche
  severity    String    @default("INFO") // INFO, WARNING, URGENT
  readAt      DateTime?

  createdAt DateTime @default(now())
}

model ContactSupportLevelHistory {
  id            String   @id @default(cuid())
  contactId     String
  contact       Contact  @relation("SupportLevelHistory", fields: [contactId], references: [id], onDelete: Cascade)
  previousLevel String?
  newLevel      String?
  changedById   String
  user          User     @relation("UserSupportLevelChanges", fields: [changedById], references: [id])
  reason        String?
  createdAt     DateTime @default(now())

  @@index([contactId])
}

model DocumentTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  entityType      String   @default("MAIL") // CONTACT, MAIL, QE, PERMANENCE
  originalName    String
  storageName     String
  storagePath     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  channel   String // EMAIL, SMS, WHATSAPP
  subject   String?
  content   String   @db.Text
  design    String?  @db.Text
  variables String // JSON array of allowed variables
  isActive  Boolean  @default(true)
  authorId  String
  author    User     @relation("TemplateAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExportBackupLog {
  id        String   @id @default(cuid())
  type      String // EXPORT_CONTACTS, BACKUP_DB
  status    String // SUCCESS, FAILED
  details   String?
  userId    String?
  user      User?    @relation("ExportBackupUser", fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

enum OrgType {
  COMMERCE
  ASSOCIATION
  MAIRIE
  MEDIA
  INSTITUTION
  OTHER
}

model Organization {
  id         String    @id @default(cuid())
  name       String
  type       OrgType   @default(OTHER)
  sector     String?
  address    String?
  city       String?
  zipCode    String?
  phone      String?
  email      String?
  website    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  permanenceOrganizations PermanenceOrganization[]
}

model Commune {
  id         String   @id @default(cuid())
  name       String
  zipCode    String
  inseeCode  String?  @unique
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  permanenceLocations PermanenceLocation[]
}

enum PermanenceStatus {
  DRAFT // Brouillon
  IN_PROGRESS // En préparation
  TO_CORRECT // À corriger
  READY // Prête
  VALIDATED // Validée
  ARCHIVED // Archivée
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  IMPOSSIBLE
}

enum CallStatus {
  NOT_CALLED
  REACHED
  ABSENT
  VOICEMAIL
  APPOINTMENT_CONFIRMED
  CALLBACK_REQUESTED
  REFUSED
}

enum ContactRole {
  PHONING
  ELU
  INSTITUTIONNEL
  PRESSE
  COMMERCANT
  CITOYEN
}

model MobilePermanence {
  id                 String           @id @default(cuid())
  title              String
  status             PermanenceStatus @default(DRAFT)
  score              Int              @default(0) // 0-100, calculé côté serveur
  scheduledStartDate DateTime
  ownerUserId        String
  ownerUser          User             @relation("PermanenceOwner", fields: [ownerUserId], references: [id])
  validationUserId   String?
  validationUser     User?            @relation("PermanenceValidator", fields: [validationUserId], references: [id])
  validationComment  String?
  notes              String?
  deputyRemarks      String? // Remarques générales du député
  returnDate         DateTime? // Date de remise
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  archivedAt         DateTime?

  locations     PermanenceLocation[]
  tasks         PermanenceTask[]
  contacts      PermanenceContact[]
  mailContacts  PermanenceMailContact[]
  organizations PermanenceOrganization[]
  synthesis     PermanenceSynthesis?
}

model PermanenceLocation {
  id              String           @id @default(cuid())
  permanenceId    String
  permanence      MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  communeId       String?
  commune         Commune?         @relation(fields: [communeId], references: [id])
  communeName     String // Dénormalisé pour affichage si commune libre
  date            DateTime
  startTime       String? // "09:00"
  endTime         String? // "12:00"
  address         String?
  parkingNotes    String?
  parkingStatus   TaskStatus       @default(TODO)
  mairieContactId String?
  mairieContact   Contact?         @relation("LocationMairieContact", fields: [mairieContactId], references: [id], onDelete: SetNull)
  locationNotes   String? // Notes libres sur ce lieu de passage
  order           Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model PermanenceTask {
  id             String           @id @default(cuid())
  permanenceId   String
  permanence     MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  section        String // "communication" | "phoning" | "courrier" | "commercants" | "institutionnel" | "logistique"
  label          String
  status         TaskStatus       @default(TODO)
  assigneeUserId String?
  assigneeUser   User?            @relation(fields: [assigneeUserId], references: [id])
  dueDate        DateTime?
  required       Boolean          @default(false)
  comment        String?
  order          Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  histories      PermanenceTaskHistory[]
}

model PermanenceTaskHistory {
  id           String         @id @default(cuid())
  taskId       String
  task         PermanenceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  action       String         // e.g. "STATUS_CHANGE", "ASSIGNEE_CHANGE", "COMMENT_ADD", "CREATED"
  oldValue     String?
  newValue     String?
  createdAt    DateTime       @default(now())
}

model PermanenceContact {
  id                      String           @id @default(cuid())
  permanenceId            String
  permanence              MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  contactId               String?
  contact                 Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  // Champs dénormalisés pour import CSV (contact sans fiche CRM)
  firstName               String?
  lastName                String?
  phone                   String?
  email                   String?
  city                    String?
  role                    ContactRole      @default(PHONING)
  callStatus              CallStatus       @default(NOT_CALLED)
  requestSummary          String?
  requiresDeputyAttention Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
}

model PermanenceOrganization {
  id               String           @id @default(cuid())
  permanenceId     String
  permanence       MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  organizationId   String?
  organization     Organization?    @relation(fields: [organizationId], references: [id])
  // Champs dénormalisés si organisation non CRM
  orgName          String?
  type             OrgType          @default(COMMERCE)
  sector           String?
  attitude         String? // "favorable" | "neutre" | "defavorable"
  concern          String?
  visitRecommended Boolean          @default(false)
  visited          Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model PermanenceSynthesis {
  id               String           @id @default(cuid())
  permanenceId     String           @unique
  permanence       MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  attentionPoints  String?
  merchantProgram  String?
  phoningTopics    String? // Sujets dominants phoning
  merchantInsights String? // Informations commerçants
  recommendations  String?
  signedByUserId   String?
  signedByUser     User?            @relation(fields: [signedByUserId], references: [id])
  signedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model AppLog {
  id        String   @id @default(cuid())
  level     String   @default("ERROR") // ERROR, WARNING, INFO
  source    String   // ex: "upload", "cron", "action:archiveQE"
  message   String
  details   Json?    // Stack trace, contexte additionnel
  userId    String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@index([source])
}

model ContactList {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  contacts    Contact[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BulkCommunication {
  id           String   @id @default(cuid())
  subject      String?
  content      String
  channel      String   // "EMAIL" ou "SMS"
  sentCount    Int
  successCount Int
  failedCount  Int
  createdAt    DateTime @default(now())
  createdBy    User     @relation("BulkCommsCreator", fields: [createdById], references: [id])
  createdById  String
}

model PermanenceMailContact {
  id           String           @id @default(cuid())
  permanenceId String
  permanence   MobilePermanence @relation(fields: [permanenceId], references: [id], onDelete: Cascade)
  contactId    String?
  contact      Contact?         @relation("MailContactRelation", fields: [contactId], references: [id], onDelete: SetNull)
  // Champs dénormalisés pour import CSV ou publipostage
  firstName    String?
  lastName     String?
  address      String?
  postalCode   String?
  city         String?
  status       String           @default("A_PREPARER") // "A_PREPARER", "ENVOYE", "NPAI"
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model PlanningComment {
  id        String   @id @default(cuid())
  date      DateTime @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([date])
}

model SavedFilter {
  id          String   @id @default(cuid())
  name        String
  description String?
  payload     String   // Le JSON stringifié contenant tous les filtres actifs
  isShared    Boolean  @default(false)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, name])
}

